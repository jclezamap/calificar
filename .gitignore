# --- REGLA DE ORO ---
# El prefijo "/" indica que el bloqueo aplica SOLO a la carpeta principal (root)

# --- PYTHON ---
__pycache__/
*.py[cod]
.ipynb_checkpoints/

# --- SCRIPTS DE GENERACIÓN (Solo en la raíz) ---
# Esto ignora los .py que crean los talleres, pero permite los .py dentro de carpetas
/*.py

# --- ARCHIVOS DE DATOS (Solo en la raíz) ---
# Evita que se suban copias locales de los datos en la carpeta principal
/*.pkl
/*.csv
/*.xlsx
/*.sqlite
/*.json
/*.txt

# --- CARPETAS DE DISTRIBUCIÓN ---
# Estas suelen estar solo en la raíz y no queremos ninguna en ningún lado
dist/
build/
*.egg-info/

# --- ENTORNOS VIRTUALES ---
venv/
.venv/
env/

# --- SISTEMA Y EDITORES ---
.DS_Store
.vscode/
.idea/

# --- EXCEPCIONES ---
# Si quieres que un archivo específico en la raíz SÍ se suba, lo desbloqueas así:
# !/setup.py